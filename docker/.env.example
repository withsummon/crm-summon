# Production environment variables for docker/docker-compose.prod.yml

# Image configuration
FRAPPE_VERSION=version-15
FRAPPE_IMAGE=registry.example.com/your-org/crm-summon:latest

# Site configuration
SITE_NAME=crm.example.com
DOMAIN=crm.example.com
ADMIN_PASSWORD=ChangeMe123!

# MariaDB credentials
MYSQL_ROOT_PASSWORD=supersecurepassword
MYSQL_DATABASE=frappe
MYSQL_USER=frappe
MYSQL_PASSWORD=frappe-password

# Optional build secret for private Git repositories
# Do not commit actual PATs or tokens into source control.
# GIT_TOKEN is used only during build with BuildKit.
GIT_TOKEN=
